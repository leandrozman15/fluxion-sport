
{
  "entities": {
    "UserProfile": {
      "title": "Perfil de Usuario",
      "description": "Información extendida del usuario con roles específicos y alcances organizacionales.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string", "description": "Teléfono de contacto personal." },
        "role": { 
          "type": "string", 
          "enum": ["admin", "fed_admin", "assoc_admin", "club_admin", "coach", "player", "referee", "coordinator"],
          "description": "Determina el alcance de permisos: global, regional, de club o individual."
        },
        "clubId": { "type": "string" },
        "dni": { "type": "string", "description": "Documento Nacional de Identidad." },
        "birthDate": { "type": "string", "format": "date" },
        "weight": { "type": "number", "description": "Peso en kilogramos." },
        "height": { "type": "number", "description": "Altura en centímetros." },
        "address": { "type": "string" },
        "bloodType": { "type": "string", "enum": ["A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-"] },
        "emergencyContact": { "type": "string" },
        "emergencyPhone": { "type": "string" },
        "tutors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "kinship": { "type": "string" },
              "phone": { "type": "string" }
            }
          },
          "description": "Lista de responsables o tutores legales."
        },
        "parkingActive": { "type": "boolean", "description": "Indica si tiene el plan de estacionamiento en el predio activo." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role"]
    },
    "Club": {
      "title": "Club / Institución",
      "description": "Entidad que gestiona jugadores y equipos locales.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "logoUrl": { "type": "string" },
        "phone": { "type": "string" }
      }
    },
    "Opponent": {
      "title": "Club Rival",
      "description": "Institución contra la que se compite en la liga.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "shortName": { "type": "string" },
        "logoUrl": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name"]
    },
    "Division": {
      "title": "Categoría / Rama",
      "description": "Rama deportiva del club (ej. Damas, Caballeros).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clubId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "trainingSessions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "day": { "type": "string" },
              "time": { "type": "string" }
            }
          }
        }
      }
    },
    "Payment": {
      "title": "Pago de Cuota",
      "description": "Registro de pago mensual de un deportista.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "month": { "type": "integer" },
        "year": { "type": "integer" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "pending", "overdue"] },
        "paymentMethod": { "type": "string" },
        "paymentDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["month", "year", "amount", "status"]
    }
  },
  "auth": {
    "providers": ["anonymous", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "Perfiles de usuario."
    },
    "/clubs/{clubId}": {
      "schema": "#/backend/entities/Club",
      "description": "Instituciones deportivas."
    },
    "/clubs/{clubId}/opponents/{opponentId}": {
      "schema": "#/backend/entities/Opponent",
      "description": "Listado de clubes rivales registrados."
    },
    "/clubs/{clubId}/players/{playerId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "Fichas de jugadores por club."
    },
    "/clubs/{clubId}/players/{playerId}/payments/{paymentId}": {
      "schema": "#/backend/entities/Payment",
      "description": "Historial de pagos del jugador."
    },
    "/clubs/{clubId}/divisions/{divisionId}": {
      "schema": "#/backend/entities/Division",
      "description": "Categorías del club."
    }
  }
}
