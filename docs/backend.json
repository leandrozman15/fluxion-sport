
{
  "entities": {
    "Federation": {
      "title": "Federación",
      "description": "Entidad de máximo nivel que agrupa asociaciones por deporte y país.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sport": { "type": "string" },
        "country": { "type": "string" },
        "logoUrl": { "type": "string", "format": "uri" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "sport", "country", "ownerId", "createdAt"]
    },
    "Association": {
      "title": "Asociación o Liga",
      "description": "Entidad regional que pertenece a una federación y agrupa clubes.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "region": { "type": "string" },
        "federationId": { "type": "string" },
        "logoUrl": { "type": "string", "format": "uri" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "region", "federationId", "createdAt"]
    },
    "Club": {
      "title": "Club",
      "description": "Entidad raíz que representa al club deportivo.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "logoUrl": { "type": "string", "format": "uri" },
        "ownerId": { "type": "string" },
        "associationId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "ownerId", "createdAt"]
    },
    "Division": {
      "title": "División",
      "description": "Categorías organizadas por edad dentro de un club.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ageMin": { "type": "number" },
        "ageMax": { "type": "number" },
        "clubId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "clubId", "createdAt"]
    },
    "Team": {
      "title": "Equipo",
      "description": "Equipos específicos dentro de una división.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "divisionId": { "type": "string" },
        "clubId": { "type": "string" },
        "coachName": { "type": "string" },
        "season": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "divisionId", "clubId", "createdAt"]
    },
    "Player": {
      "title": "Jugador",
      "description": "Datos personales y deportivos de un jugador.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoUrl": { "type": "string", "format": "uri" },
        "position": { "type": "string" },
        "jerseyNumber": { "type": "number" },
        "clubId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "firstName", "lastName", "clubId", "createdAt"]
    },
    "TeamPlayer": {
      "title": "Asignación de Jugador",
      "description": "Relación entre un jugador y un equipo.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "playerId": { "type": "string" },
        "playerName": { "type": "string" },
        "playerPhoto": { "type": "string" },
        "teamId": { "type": "string" },
        "season": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "playerId", "teamId", "season"]
    },
    "Event": {
      "title": "Evento",
      "description": "Entrenamiento, partido o evento social del equipo.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["training", "match", "event"] },
        "teamId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "address": { "type": "string" },
        "opponent": { "type": "string" },
        "description": { "type": "string" },
        "homeScore": { "type": "number" },
        "awayScore": { "type": "number" },
        "matchFinished": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "type", "teamId", "date", "createdAt"]
    },
    "MatchStat": {
      "title": "Estadística de Partido",
      "description": "Registro de desempeño de un jugador en un partido.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "eventId": { "type": "string" },
        "playerId": { "type": "string" },
        "playerName": { "type": "string" },
        "goals": { "type": "number" },
        "assists": { "type": "number" },
        "yellowCards": { "type": "number" },
        "redCards": { "type": "number" },
        "minutesPlayed": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "eventId", "playerId", "goals", "assists", "yellowCards", "redCards", "minutesPlayed"]
    }
  },
  "auth": {
    "providers": ["anonymous", "password"]
  },
  "firestore": {
    "/federations/{fedId}": {
      "schema": "#/backend/entities/Federation",
      "description": "Colección de federaciones."
    },
    "/federations/{fedId}/associations/{assocId}": {
      "schema": "#/backend/entities/Association",
      "description": "Asociaciones por federación."
    },
    "/clubs/{clubId}": {
      "schema": "#/backend/entities/Club",
      "description": "Colección de clubes vinculados opcionalmente a asociaciones."
    },
    "/clubs/{clubId}/divisions/{divisionId}": {
      "schema": "#/backend/entities/Division",
      "description": "Divisiones por club."
    }
  }
}
