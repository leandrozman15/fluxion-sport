
{
  "entities": {
    "Club": {
      "title": "Club",
      "description": "Entidad raíz que representa al club deportivo.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "logoUrl": { "type": "string", "format": "uri" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "ownerId", "createdAt"]
    },
    "Division": {
      "title": "División",
      "description": "Categorías organizadas por edad dentro de un club (ej. Sub 9).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ageMin": { "type": "number" },
        "ageMax": { "type": "number" },
        "clubId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "clubId", "createdAt"]
    },
    "Team": {
      "title": "Equipo",
      "description": "Equipos específicos dentro de una división (ej. Sub 11 A).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "divisionId": { "type": "string" },
        "clubId": { "type": "string" },
        "coachName": { "type": "string" },
        "season": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "divisionId", "clubId", "createdAt"]
    }
  },
  "auth": {
    "providers": ["anonymous", "password"]
  },
  "firestore": {
    "/clubs/{clubId}": {
      "schema": "#/backend/entities/Club",
      "description": "Colección de clubes."
    },
    "/clubs/{clubId}/divisions/{divisionId}": {
      "schema": "#/backend/entities/Division",
      "description": "Divisiones por club."
    },
    "/clubs/{clubId}/divisions/{divisionId}/teams/{teamId}": {
      "schema": "#/backend/entities/Team",
      "description": "Equipos por división."
    }
  }
}
