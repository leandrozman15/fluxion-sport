
{
  "entities": {
    "Club": {
      "title": "Club",
      "description": "Entidad raíz que representa al club deportivo.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "logoUrl": { "type": "string", "format": "uri" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "ownerId", "createdAt"]
    },
    "Division": {
      "title": "División",
      "description": "Categorías organizadas por edad dentro de un club.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ageMin": { "type": "number" },
        "ageMax": { "type": "number" },
        "clubId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "clubId", "createdAt"]
    },
    "Team": {
      "title": "Equipo",
      "description": "Equipos específicos dentro de una división.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "divisionId": { "type": "string" },
        "clubId": { "type": "string" },
        "coachName": { "type": "string" },
        "season": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "divisionId", "clubId", "createdAt"]
    },
    "Player": {
      "title": "Jugador",
      "description": "Datos personales y deportivos de un jugador.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoUrl": { "type": "string", "format": "uri" },
        "position": { "type": "string" },
        "jerseyNumber": { "type": "number" },
        "clubId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "firstName", "lastName", "clubId", "createdAt"]
    },
    "TeamPlayer": {
      "title": "Asignación de Jugador",
      "description": "Relación entre un jugador y un equipo.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "playerId": { "type": "string" },
        "playerName": { "type": "string" },
        "playerPhoto": { "type": "string" },
        "teamId": { "type": "string" },
        "season": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "playerId", "teamId", "season"]
    },
    "Event": {
      "title": "Evento",
      "description": "Entrenamiento, partido o evento social del equipo.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["training", "match", "event"] },
        "teamId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "address": { "type": "string" },
        "opponent": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "type", "teamId", "date", "createdAt"]
    },
    "MatchStat": {
      "title": "Estadística de Partido",
      "description": "Registro de goles y asistencias de un jugador en un partido.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "eventId": { "type": "string" },
        "playerId": { "type": "string" },
        "playerName": { "type": "string" },
        "goals": { "type": "number" },
        "assists": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "eventId", "playerId", "goals", "assists"]
    },
    "Attendance": {
      "title": "Asistencia",
      "description": "Confirmación de asistencia de un jugador a un evento.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "eventId": { "type": "string" },
        "playerId": { "type": "string" },
        "playerName": { "type": "string" },
        "status": { "type": "string", "enum": ["going", "not_going", "pending"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "eventId", "playerId", "status", "updatedAt"]
    },
    "MatchCallup": {
      "title": "Convocatoria",
      "description": "Lista de jugadores seleccionados para un partido específico.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "eventId": { "type": "string" },
        "playerId": { "type": "string" },
        "playerName": { "type": "string" },
        "status": { "type": "string", "enum": ["called", "confirmed", "declined"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "eventId", "playerId", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": ["anonymous", "password"]
  },
  "firestore": {
    "/clubs/{clubId}": {
      "schema": "#/backend/entities/Club",
      "description": "Colección de clubes."
    },
    "/clubs/{clubId}/divisions/{divisionId}": {
      "schema": "#/backend/entities/Division",
      "description": "Divisiones por club."
    },
    "/clubs/{clubId}/divisions/{divisionId}/teams/{teamId}": {
      "schema": "#/backend/entities/Team",
      "description": "Equipos por división."
    },
    "/clubs/{clubId}/players/{playerId}": {
      "schema": "#/backend/entities/Player",
      "description": "Jugadores del club."
    },
    "/clubs/{clubId}/divisions/{divisionId}/teams/{teamId}/assignments/{assignmentId}": {
      "schema": "#/backend/entities/TeamPlayer",
      "description": "Plantel del equipo."
    },
    "/clubs/{clubId}/divisions/{divisionId}/teams/{teamId}/events/{eventId}": {
      "schema": "#/backend/entities/Event",
      "description": "Eventos del equipo."
    },
    "/clubs/{clubId}/divisions/{divisionId}/teams/{teamId}/events/{eventId}/stats/{statId}": {
      "schema": "#/backend/entities/MatchStat",
      "description": "Estadísticas de jugadores por partido."
    },
    "/clubs/{clubId}/divisions/{divisionId}/teams/{teamId}/events/{eventId}/attendance/{attendanceId}": {
      "schema": "#/backend/entities/Attendance",
      "description": "Asistencia a eventos."
    },
    "/clubs/{clubId}/divisions/{divisionId}/teams/{teamId}/events/{eventId}/callups/{callupId}": {
      "schema": "#/backend/entities/MatchCallup",
      "description": "Convocatorias para partidos."
    }
  }
}
