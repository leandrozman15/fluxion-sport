{
  "entities": {
    "UserProfile": {
      "title": "Perfil de Usuario",
      "description": "Información extendida del usuario con roles específicos y alcances organizacionales.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { 
          "type": "string", 
          "enum": ["admin", "fed_admin", "assoc_admin", "club_admin", "coach", "player", "referee"],
          "description": "Determina el alcance de permisos: global, regional, de club o individual."
        },
        "clubId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Club": {
      "title": "Club / Institución",
      "description": "Entidad que gestiona jugadores y equipos locales.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "logoUrl": { "type": "string" },
        "phone": { "type": "string" }
      }
    },
    "ShopProduct": {
      "title": "Producto de Tienda",
      "description": "Artículos de merchandising o indumentaria del club.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["indumentaria", "equipamiento", "accesorios"] },
        "photoUrl": { "type": "string" },
        "stock": { "type": "number" }
      }
    },
    "Match": {
      "title": "Encuentro Deportivo",
      "description": "Datos de un partido oficial o entrenamiento.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string" },
        "opponent": { "type": "string" },
        "location": { "type": "string" },
        "status": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["anonymous", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "Perfiles de usuario."
    },
    "/clubs/{clubId}": {
      "schema": "#/backend/entities/Club",
      "description": "Instituciones deportivas."
    },
    "/clubs/{clubId}/shop_products/{productId}": {
      "schema": "#/backend/entities/ShopProduct",
      "description": "Catálogo de productos de la tienda."
    },
    "/all_players_index/{playerId}": {
      "schema": { "type": "object" },
      "description": "Índice global para búsqueda transversal de jugadores."
    },
    "/match_callups/{callupId}": {
      "schema": { "type": "object" },
      "description": "Citaciones de jugadores a partidos."
    }
  }
}