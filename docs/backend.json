
{
  "entities": {
    "UserProfile": {
      "title": "Perfil de Usuario",
      "description": "Información extendida del usuario con roles específicos y alcances organizacionales.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string", "description": "Teléfono de contacto personal." },
        "role": { 
          "type": "string", 
          "enum": ["admin", "fed_admin", "assoc_admin", "club_admin", "coach", "player", "referee", "coordinator"],
          "description": "Determina el alcance de permisos: global, regional, de club o individual."
        },
        "clubId": { "type": "string" },
        "clubName": { "type": "string" },
        "dni": { "type": "string", "description": "Documento Nacional de Identidad." },
        "birthDate": { "type": "string", "format": "date" },
        "weight": { "type": "number" },
        "height": { "type": "number" },
        "photoUrl": { "type": "string", "description": "URL base64 o remota de la foto de perfil." },
        "sport": { "type": "string", "enum": ["hockey", "rugby"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role"]
    },
    "Club": {
      "title": "Club / Institución",
      "description": "Entidad que gestiona jugadores y equipos locales.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "logoUrl": { "type": "string" },
        "phone": { "type": "string" }
      }
    },
    "SpecialEvent": {
      "title": "Evento Especial",
      "description": "Comunicado oficial con imagen y comentario para todo el club.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clubId": { "type": "string" },
        "title": { "type": "string" },
        "comment": { "type": "string" },
        "imageUrl": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "clubId", "createdAt"]
    },
    "LiveMatch": {
      "title": "Partido en Vivo",
      "description": "Estado de un partido en tiempo real para el monitor global.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clubId": { "type": "string" },
        "teamName": { "type": "string" },
        "opponentName": { "type": "string" },
        "homeScore": { "type": "number" },
        "awayScore": { "type": "number" },
        "timeDisplay": { "type": "string" },
        "status": { "type": "string", "enum": ["live", "finished"] }
      }
    }
  },
  "auth": {
    "providers": ["anonymous", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "Cuentas de Staff y Administradores."
    },
    "/clubs/{clubId}": {
      "schema": "#/backend/entities/Club",
      "description": "Instituciones deportivas."
    },
    "/clubs/{clubId}/special_events/{eventId}": {
      "schema": "#/backend/entities/SpecialEvent",
      "description": "Novedades institucionales visibles para todos."
    },
    "/clubs/{clubId}/players/{playerId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "Fichas individuales del padrón del club."
    },
    "/all_players_index/{playerId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "Índice global para acceso de socios por email."
    },
    "/live_matches_index/{matchId}": {
      "schema": "#/backend/entities/LiveMatch",
      "description": "Monitor de partidos en tiempo real."
    }
  }
}
