
{
  "entities": {
    "UserProfile": {
      "title": "Perfil de Usuario",
      "description": "Información extendida del usuario con roles específicos y alcances organizacionales.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { 
          "type": "string", 
          "enum": ["admin", "fed_admin", "assoc_admin", "club_admin", "coach", "player", "referee"],
          "description": "Determina el alcance de permisos: global, regional, de club o individual."
        },
        "federationId": { "type": "string", "description": "ID de la federación nacional vinculada." },
        "associationId": { "type": "string", "description": "ID de la asociación regional vinculada." },
        "clubId": { "type": "string", "description": "ID del club vinculado." },
        "teamId": { "type": "string", "description": "ID del equipo específico (principalmente para jugadores/coaches)." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Federation": {
      "title": "Federación Nacional",
      "description": "Entidad de máximo nivel (ej. CAH).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sport": { "type": "string" },
        "country": { "type": "string" },
        "logoUrl": { "type": "string" },
        "config": { "type": "object" }
      }
    },
    "Association": {
      "title": "Asociación Regional",
      "description": "Entidad regional que gestiona ligas y árbitros.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "federationId": { "type": "string" },
        "name": { "type": "string" },
        "region": { "type": "string" },
        "logoUrl": { "type": "string" }
      }
    },
    "Club": {
      "title": "Club / Institución",
      "description": "Entidad que gestiona jugadores y equipos locales.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "associationId": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "logoUrl": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["anonymous", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "Perfiles de usuario con alcance organizacional."
    },
    "/federations/{fedId}": {
      "schema": "#/backend/entities/Federation",
      "description": "Datos de federaciones nacionales."
    },
    "/federations/{fedId}/associations/{assocId}": {
      "schema": "#/backend/entities/Association",
      "description": "Asociaciones regionales vinculadas a una federación."
    },
    "/clubs/{clubId}": {
      "schema": "#/backend/entities/Club",
      "description": "Instituciones deportivas."
    }
  }
}
