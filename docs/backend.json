
{
  "entities": {
    "UserProfile": {
      "title": "Perfil de Usuario",
      "description": "Información extendida del usuario con roles específicos y alcances organizacionales.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "role": { 
          "type": "string", 
          "enum": ["admin", "fed_admin", "assoc_admin", "club_admin", "coach_lvl1", "coach_lvl2", "coach", "player", "referee", "coordinator"]
        },
        "clubId": { "type": "string" },
        "clubName": { "type": "string" },
        "dni": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "weight": { "type": "number" },
        "height": { "type": "number" },
        "photoUrl": { "type": "string" },
        "sport": { "type": "string", "enum": ["hockey", "rugby"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role"]
    },
    "Club": {
      "title": "Club / Institución",
      "description": "Entidad que gestiona jugadores y equipos locales.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "logoUrl": { "type": "string" },
        "phone": { "type": "string" }
      }
    },
    "Payment": {
      "title": "Pago / Cuota Social",
      "description": "Registro de pago mensual de un socio.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "playerId": { "type": "string" },
        "month": { "type": "number" },
        "year": { "type": "number" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "pending", "overdue"] },
        "paymentMethod": { "type": "string" },
        "paymentDate": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["anonymous", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "Cuentas de Staff y Administradores."
    },
    "/clubs/{clubId}": {
      "schema": "#/backend/entities/Club",
      "description": "Instituciones deportivas."
    },
    "/clubs/{clubId}/players/{playerId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "Fichas individuales del club."
    },
    "/clubs/{clubId}/players/{playerId}/payments/{paymentId}": {
      "schema": "#/backend/entities/Payment",
      "description": "Historial de pagos del socio."
    },
    "/all_players_index/{playerId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "Índice global para acceso de socios."
    }
  }
}
