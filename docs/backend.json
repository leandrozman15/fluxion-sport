
{
  "entities": {
    "UserProfile": {
      "title": "Perfil de Usuario",
      "description": "Información extendida del usuario con roles específicos.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "fed_admin", "assoc_admin", "club_admin", "coach", "player", "referee"] },
        "federationId": { "type": "string" },
        "associationId": { "type": "string" },
        "clubId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Team": {
      "title": "Equipo",
      "description": "Plantilla específica de una subcategoría.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "coachId": { "type": "string", "description": "UID del entrenador asignado." },
        "coachName": { "type": "string" },
        "season": { "type": "string" },
        "subcategoryId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "TeamEvent": {
      "title": "Evento de Equipo",
      "description": "Entrenamiento o partido programado por el entrenador.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["training", "match", "social"] },
        "date": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "attendanceTaken": { "type": "boolean" }
      }
    },
    "Tournament": {
      "title": "Torneo",
      "description": "Competición organizada por federación o asociación.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "organizerId": { "type": "string" },
        "season": { "type": "string" },
        "sport": { "type": "string" },
        "startDate": { "type": "string", "format": "date" }
      }
    }
  },
  "auth": {
    "providers": ["anonymous", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "Perfiles de usuario."
    },
    "/clubs/{clubId}/divisions/{divId}/subcategories/{subId}/teams/{teamId}": {
      "schema": "#/backend/entities/Team",
      "description": "Gestión de equipos."
    },
    "/clubs/{clubId}/divisions/{divId}/subcategories/{subId}/teams/{teamId}/events/{eventId}": {
      "schema": "#/backend/entities/TeamEvent",
      "description": "Agenda del equipo."
    }
  }
}
