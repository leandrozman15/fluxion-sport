
{
  "entities": {
    "UserProfile": {
      "title": "Perfil de Usuario",
      "description": "Información extendida del usuario con roles específicos.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "coach", "player", "referee"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role"]
    },
    "ClubDivision": {
      "title": "División de Club",
      "description": "Agrupación general de categorías (ej. Inferiores, Femenino).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clubId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "clubId", "name"]
    },
    "Subcategory": {
      "title": "Subcategoría",
      "description": "Categoría específica por edad dentro de una división (ej. 9na, Sub 15).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "divisionId": { "type": "string" },
        "name": { "type": "string" },
        "ageRange": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "divisionId", "name"]
    },
    "Tournament": {
      "title": "Torneo",
      "description": "Competición organizada por una federación o asociación.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "organizerId": { "type": "string" },
        "organizerType": { "type": "string", "enum": ["federation", "association"] },
        "season": { "type": "string" },
        "sport": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "logoUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "organizerId", "season"]
    },
    "TournamentCategory": {
      "title": "Categoría de Torneo",
      "description": "Divisiones por edad o nivel dentro de un torneo.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tournamentId": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "tournamentId", "name"]
    },
    "TournamentTeam": {
      "title": "Equipo Inscrito",
      "description": "Relación de un equipo de club con una categoría de torneo.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tournamentCategoryId": { "type": "string" },
        "teamId": { "type": "string" },
        "clubId": { "type": "string" },
        "teamName": { "type": "string" },
        "clubName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "tournamentCategoryId", "teamId", "clubId"]
    },
    "TournamentMatch": {
      "title": "Partido de Torneo",
      "description": "Encuentro oficial programado en el fixture.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tournamentId": { "type": "string" },
        "categoryId": { "type": "string" },
        "homeTeamId": { "type": "string" },
        "homeTeamName": { "type": "string" },
        "awayTeamId": { "type": "string" },
        "awayTeamName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "refereeId": { "type": "string" },
        "status": { "type": "string", "enum": ["scheduled", "played", "cancelled"] },
        "homeScore": { "type": "number" },
        "awayScore": { "type": "number" }
      },
      "required": ["id", "tournamentId", "categoryId", "homeTeamId", "awayTeamId", "date"]
    }
  },
  "auth": {
    "providers": ["anonymous", "password"]
  },
  "firestore": {
    "/tournaments/{tournamentId}": {
      "schema": "#/backend/entities/Tournament",
      "description": "Colección central de torneos."
    },
    "/tournament_matches/{matchId}": {
      "schema": "#/backend/entities/TournamentMatch",
      "description": "Calendario centralizado de partidos de todos los torneos."
    },
    "/federations/{fedId}": {
      "schema": "#/backend/entities/Federation",
      "description": "Federaciones deportivas."
    },
    "/clubs/{clubId}/divisions/{divisionId}/subcategories/{subcatId}": {
      "schema": "#/backend/entities/Subcategory",
      "description": "Subcategorías específicas dentro de una división de club."
    }
  }
}
