
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(docData) {
      return isSignedIn() && docData.ownerId == request.auth.uid;
    }

    match /federations/{fedId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data);

      match /associations/{assocId} {
        allow get, list: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn(); // Para simplificar MVP
      }
    }

    match /clubs/{clubId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data);

      match /players/{playerId} {
        allow get, list: if true;
        allow create, update, delete: if isSignedIn();

        match /payments/{paymentId} {
          allow list, get: if isSignedIn();
          allow create, update, delete: if isSignedIn();
        }
      }

      match /divisions/{divisionId} {
        allow get, list: if true;
        allow create, update, delete: if isSignedIn();

        match /teams/{teamId} {
          allow get, list: if true;
          allow create, update, delete: if isSignedIn();

          match /assignments/{assignmentId} {
            allow get, list: if true;
            allow create, update, delete: if isSignedIn();
          }

          match /events/{eventId} {
            allow get, list: if true;
            allow create, update, delete: if isSignedIn();

            match /attendance/{attendanceId} {
              allow get, list: if true;
              allow create, update, delete: if isSignedIn();
            }

            match /callups/{callupId} {
              allow get, list: if true;
              allow create, update, delete: if isSignedIn();
            }

            match /stats/{statId} {
              allow get, list: if true;
              allow create, update, delete: if isSignedIn();
            }
          }
        }
      }
    }
  }
}
