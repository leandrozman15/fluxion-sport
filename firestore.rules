
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS DE ACCESO TOTAL PARA PROTOTIPADO Y DESARROLLO
    // Permite lectura y escritura pública en todas las colecciones para facilitar el cadastro y las pruebas de staff.
    // Nota: Se ha forzado la actualización de reglas para la base de datos específica.
    
    match /{document=**} {
      allow read, write: if true;
    }

    // Reglas explícitas para asegurar que las rutas complejas funcionen sin fricción
    match /clubs/{clubId} {
      allow read, write: if true;
      
      match /{allSubcollections=**} {
        allow read, write: if true;
      }
    }

    match /users/{userId} {
      allow read, write: if true;
    }
    
    match /all_players_index/{playerId} {
      allow read, write: if true;
    }
    
    match /live_matches_index/{matchId} {
      allow read, write: if true;
    }
  }
}
