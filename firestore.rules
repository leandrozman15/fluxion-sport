
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS DE ACCESO TOTAL PARA PROTOTIPADO (Refresco forzado para base de datos específica)
    // Permite lectura y escritura pública en todas las colecciones para facilitar el desarrollo.
    
    match /{document=**} {
      allow read, write: if true;
    }

    match /clubs/{clubId} {
      allow read, write: if true;
      match /{allSubcollections=**} {
        allow read, write: if true;
      }
    }

    match /users/{userId} {
      allow read, write: if true;
    }
    
    match /all_players_index/{playerId} {
      allow read, write: if true;
    }
    
    match /live_matches_index/{matchId} {
      allow read, write: if true;
    }
  }
}
