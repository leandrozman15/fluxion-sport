
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS DE ACCESO TOTAL PARA PROTOTIPADO Y DESARROLLO
    // Permite lectura y escritura pública en todas las colecciones para facilitar el cadastro y las pruebas de staff.
    
    match /{document=**} {
      allow read, write: if true;
    }

    // Reglas explícitas para asegurar que las rutas complejas con caracteres especiales (@) funcionen sin fricción
    match /clubs/{clubId}/players/{playerId} {
      allow read, write: if true;
      
      // Permitir acceso total a subcolecciones como 'payments' o 'attendance'
      match /{allSubcollections=**} {
        allow read, write: if true;
      }
    }

    match /users/{userId} {
      allow read, write: if true;
    }
    
    match /all_players_index/{playerId} {
      allow read, write: if true;
    }
  }
}
