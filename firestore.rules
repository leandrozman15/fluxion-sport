
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Función básica de autenticación
    function isSignedIn() {
      return request.auth != null;
    }

    // Permitimos lectura y escritura completa durante la fase de prototipado 
    // para asegurar que el creador pueda gestionar todo el ecosistema.
    match /{path=**} {
      allow read, write: if true;
    }
  }
}
