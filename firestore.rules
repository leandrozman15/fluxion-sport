
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Función básica de autenticación
    function isSignedIn() {
      return request.auth != null;
    }

    // Función para obtener datos del perfil de usuario
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Verificar si el usuario tiene un rol específico
    function isRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    // Verificar si es administrador global
    function isGlobalAdmin() {
      return isRole('admin');
    }

    // PERMISOS DE LECTURA: Toda la información deportiva es pública para facilitar el ecosistema
    match /{path=**} {
      allow read: if true;
    }

    // PERMISOS DE ESCRITURA: Reglas jerárquicas y recursivas

    // Federaciones y todas sus subcolecciones (Asociaciones, etc)
    match /federations/{fedId} {
      allow write: if isSignedIn();
      match /{allSubcollections=**} {
        allow write: if isSignedIn();
      }
    }

    // Clubes y todas sus subcolecciones (Jugadores, Divisiones, Subcategorías, Equipos, Eventos, Pagos, Stats)
    match /clubs/{clubId} {
      allow write: if isSignedIn();
      match /{allSubcollections=**} {
        allow write: if isSignedIn();
      }
    }

    // Torneos y sus subcolecciones (Categorías, Equipos inscritos)
    match /tournaments/{tournamentId} {
      allow write: if isSignedIn();
      match /{allSubcollections=**} {
        allow write: if isSignedIn();
      }
    }

    // Colecciones Globales (Fixture centralizado y eventos de partido)
    match /tournament_matches/{matchId} {
      allow write: if isSignedIn();
    }
    match /match_callups/{callupId} {
      allow write: if isSignedIn();
    }
    match /match_events/{eventId} {
      allow write: if isSignedIn();
    }

    // Usuarios: Un usuario solo puede gestionar su propio documento de perfil
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }
    
    // Comentario para forzar despliegue de reglas corregidas
  }
}
