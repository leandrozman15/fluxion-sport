
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    // Reglas para Perfiles de Usuario
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Reglas para Torneos y Fixture
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();

      match /categories/{catId} {
        allow read: if true;
        allow write: if isSignedIn();

        match /teams/{teamId} {
          allow read: if true;
          allow write: if isSignedIn();
        }
      }
    }

    match /tournament_matches/{matchId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.refereeId || 
        isRole('admin') ||
        isRole('coach')
      );
      allow delete: if isSignedIn() && isRole('admin');
    }

    // Reglas para Federaciones
    match /federations/{fedId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.ownerId || isRole('admin'));

      match /associations/{assocId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    // Reglas para Clubes
    match /clubs/{clubId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.ownerId || isRole('admin'));

      match /players/{playerId} {
        allow read: if true;
        allow write: if isSignedIn();
        match /payments/{paymentId} {
          allow read, write: if isSignedIn();
        }
      }

      match /divisions/{divisionId} {
        allow read: if true;
        allow write: if isSignedIn();
        match /teams/{teamId} {
          allow read: if true;
          allow write: if isSignedIn();
          match /assignments/{assignmentId} {
            allow read, write: if isSignedIn();
          }
          match /events/{eventId} {
            allow read, write: if isSignedIn();
            match /attendance/{attId} { allow read, write: if isSignedIn(); }
            match /stats/{statId} { allow read, write: if isSignedIn(); }
            match /callups/{callId} { allow read, write: if isSignedIn(); }
          }
        }
      }
    }
    
    // Reglas para eventos globales de partido
    match /match_events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }
  }
}
