
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    // Un admin global puede hacer todo
    function isGlobalAdmin() {
      return isRole('admin');
    }

    // Permisos de Federaciones
    match /federations/{fedId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.ownerId || isGlobalAdmin());

      match /associations/{assocId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    // Permisos de Clubes
    match /clubs/{clubId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.ownerId || isGlobalAdmin());

      match /players/{playerId} {
        allow read: if true;
        allow write: if isSignedIn();
        match /payments/{paymentId} { allow read, write: if isSignedIn(); }
      }

      match /divisions/{divisionId} {
        allow read: if true;
        allow write: if isSignedIn();
        match /subcategories/{subcatId} {
          allow read: if true;
          allow write: if isSignedIn();
          match /teams/{teamId} {
            allow read: if true;
            allow write: if isSignedIn();
            match /assignments/{assignmentId} { allow read, write: if isSignedIn(); }
            match /events/{eventId} {
              allow read, write: if isSignedIn();
              match /stats/{statId} { allow read, write: if isSignedIn(); }
            }
          }
        }
      }
    }

    // Torneos y Fixture
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow write: if isSignedIn();
      match /categories/{catId} {
        allow read: if true;
        allow write: if isSignedIn();
        match /teams/{teamId} { allow read, write: if isSignedIn(); }
      }
    }

    match /tournament_matches/{matchId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /match_callups/{callupId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /match_events/{eventId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
