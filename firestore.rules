
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    // Reglas para Perfiles de Usuario
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Reglas para Eventos de Partido (Goles, etc)
    match /match_events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn() && (isRole('referee') || isRole('admin'));
    }

    // Reglas para Federaciones y sus subcolecciones
    match /federations/{fedId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.ownerId || isRole('admin'));

      match /associations/{assocId} {
        allow read: if true;
        allow create, update, delete: if isSignedIn();
      }
    }

    // Reglas para Clubes y su jerarquía completa
    match /clubs/{clubId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.ownerId || isRole('admin'));

      match /players/{playerId} {
        allow read: if true;
        allow create, update, delete: if isSignedIn();

        match /payments/{paymentId} {
          allow read, get: if isSignedIn();
          allow create, update, delete: if isSignedIn();
        }
      }

      match /divisions/{divisionId} {
        allow read: if true;
        allow create, update, delete: if isSignedIn();

        match /teams/{teamId} {
          allow read: if true;
          allow create, update, delete: if isSignedIn();

          match /assignments/{assignmentId} {
            allow read: if true;
            allow create, update, delete: if isSignedIn();
          }

          match /events/{eventId} {
            allow read: if true;
            allow create, update, delete: if isSignedIn();
            // Permitir que el árbitro actualice el resultado
            allow update: if isSignedIn() && (
              request.auth.uid == resource.data.refereeId || 
              request.auth.uid == resource.data.assistantRefereeId ||
              isRole('coach') ||
              isRole('admin')
            );

            match /stats/{statId} {
              allow read: if true;
              allow create, update, delete: if isSignedIn();
            }
          }
        }
      }
    }
  }
}
