
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funciones de Ayuda
    function isAuthenticated() {
      return request.auth != null;
    }

    function isStaffMember() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isPlayerMember() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/all_players_index/$(request.auth.uid));
    }

    function isMember() {
      return isStaffMember() || isPlayerMember();
    }

    // --- Usuarios (staff) ---
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isStaffMember();
    }

    // --- Clubs y sub-colecciones ---
    match /clubs/{clubId} {
      allow read: if isAuthenticated();
      allow write: if isStaffMember();

      match /{subcol=**} {
        allow read: if isAuthenticated();
        allow write: if isStaffMember();
      }
    }

    // --- Índice global de jugadores ---
    match /all_players_index/{playerId} {
      allow read: if isAuthenticated();
      allow write: if isStaffMember();
    }

    // --- Registro público de jugadores (sin autenticación) ---
    match /clubs/{clubId}/players/{playerId} {
      allow create: if true;
    }
    match /all_players_index/{playerId} {
      allow create: if true;
    }
  }
}
