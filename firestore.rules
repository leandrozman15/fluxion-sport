
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Función básica de autenticación
    function isSignedIn() {
      return request.auth != null;
    }

    // Permitimos acceso total durante desarrollo para evitar bloqueos en el prototipado
    // En producción se deberían segmentar por roles específicos
    match /{path=**} {
      allow read, write: if true;
    }
  }
}
