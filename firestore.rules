
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isClubOwner(clubId) {
      return isSignedIn() && get(/databases/$(database)/documents/clubs/$(clubId)).data.ownerId == request.auth.uid;
    }

    match /clubs/{clubId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      match /players/{playerId} {
        allow get, list: if true;
        allow create, update, delete: if isClubOwner(clubId);

        match /payments/{paymentId} {
          allow list, get: if isSignedIn();
          allow create, update, delete: if isClubOwner(clubId);
        }
      }

      match /divisions/{divisionId} {
        allow get, list: if true;
        allow create, update, delete: if isClubOwner(clubId);

        match /teams/{teamId} {
          allow get, list: if true;
          allow create, update, delete: if isClubOwner(clubId);

          match /assignments/{assignmentId} {
            allow get, list: if true;
            allow create, update, delete: if isClubOwner(clubId);
          }

          match /events/{eventId} {
            allow get, list: if true;
            allow create, update, delete: if isClubOwner(clubId);

            match /attendance/{attendanceId} {
              allow get, list: if true;
              allow create, update, delete: if isSignedIn();
            }

            match /callups/{callupId} {
              allow get, list: if true;
              allow create, delete: if isClubOwner(clubId);
              allow update: if isSignedIn();
            }

            match /stats/{statId} {
              allow get, list: if true;
              allow create, update, delete: if isClubOwner(clubId);
            }
          }
        }
      }
    }
  }
}
