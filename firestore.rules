
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(docData) {
      return isSignedIn() && docData != null && docData.ownerId == request.auth.uid;
    }

    // Reglas para Federaciones y sus subcolecciones
    match /federations/{fedId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data);

      match /associations/{assocId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn();
      }
    }

    // Reglas para Clubes y su jerarquía completa
    match /clubs/{clubId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data);

      match /players/{playerId} {
        allow read: if true;
        allow create, update, delete: if isSignedIn();

        match /payments/{paymentId} {
          allow read, get: if isSignedIn();
          allow create, update, delete: if isSignedIn();
        }
      }

      match /divisions/{divisionId} {
        allow read: if true;
        allow create, update, delete: if isSignedIn();

        match /standings/{standingId} {
          allow read: if true;
          allow create, update, delete: if isSignedIn();
        }

        match /teams/{teamId} {
          allow read: if true;
          allow create, update, delete: if isSignedIn();

          match /assignments/{assignmentId} {
            allow read: if true;
            allow create, update, delete: if isSignedIn();
          }

          match /events/{eventId} {
            allow read: if true;
            allow create, update, delete: if isSignedIn();

            match /attendance/{attendanceId} {
              allow read: if true;
              allow create, update, delete: if isSignedIn();
            }

            match /callups/{callupId} {
              allow read: if true;
              allow create, update, delete: if isSignedIn();
            }

            match /stats/{statId} {
              allow read: if true;
              allow create, update, delete: if isSignedIn();
            }
          }
        }
      }
    }
  }
}
// Despliegue de reglas actualizado para corregir permisos de federaciones y subcolecciones.
