
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS DE ACCESO TOTAL PARA PROTOTIPADO Y DESARROLLO
    // Permite lectura y escritura pública en todas las colecciones para facilitar el cadastro y las pruebas de staff.
    
    match /{document=**} {
      allow read, write: if true;
    }

    // Regla explícita para la colección de usuarios para asegurar que setDoc y updateDoc funcionen sin fricción
    match /users/{userId} {
      allow read, write: if true;
    }
    
    // Regla para el índice de jugadores
    match /all_players_index/{playerId} {
      allow read, write: if true;
    }
  }
}
