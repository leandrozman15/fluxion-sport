
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas globales para prototipado rápido
    // Versión: 1.0.2 - Re-desplegando para corregir error de permisos en subcolección de pagos
    match /{document=**} {
      allow read, write: if true;
    }

    // Regla explícita para la ruta de pagos de jugadores
    match /clubs/{clubId}/players/{playerId}/payments/{paymentId} {
      allow read, write: if true;
    }
  }
}
